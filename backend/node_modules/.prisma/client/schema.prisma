generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum ScanStatus {
  PENDING
  CLONING
  SCANNING
  PROCESSING
  AI_ANALYSIS
  COMPLETED
  FAILED
}

enum ScanSource {
  GITHUB
  ZIP_UPLOAD
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  WARNING
  INFO
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        String   @id @default(cuid())
  githubId  String?  @unique
  username  String   @unique
  email     String?  @unique
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
  scans    Scan[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  repoUrl     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scans Scan[]

  @@index([userId])
  @@map("projects")
}

model Scan {
  id       String     @id @default(cuid())
  status   ScanStatus @default(PENDING)
  source   ScanSource
  inputRef String

  // Results
  riskScore     Float @default(0)
  totalIssues   Int   @default(0)
  criticalCount Int   @default(0)
  highCount     Int   @default(0)
  mediumCount   Int   @default(0)
  lowCount      Int   @default(0)
  warningCount  Int   @default(0)

  // Meta
  duration Int?
  errorMsg String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  issues Issue[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("scans")
}

model Issue {
  id          String   @id @default(cuid())
  ruleId      String
  title       String
  description String   @db.Text
  severity    Severity
  category    String

  // Location
  filePath    String
  lineStart   Int
  lineEnd     Int
  codeSnippet String? @db.Text

  // CVE / CWE / OWASP
  cweId     String?
  owaspId   String?
  cvssScore Float?

  // AI Enhancement
  aiExplanation    String?   @db.Text
  aiImpact         String?   @db.Text
  aiProofOfConcept String?   @db.Text
  aiRemediation    String?   @db.Text
  aiFixCode        String?   @db.Text
  aiProcessed      Boolean   @default(false)
  aiProcessedAt    DateTime?

  createdAt DateTime @default(now())

  scanId String
  scan   Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([severity])
  @@index([ruleId])
  @@index([aiProcessed])
  @@map("issues")
}
